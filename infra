#!/usr/bin/env bash

set -e
set -o pipefail

INFRA_ROOT=$(cd "$(dirname "$0")" && pwd)
CENTRAL_INFRA_DIR="$INFRA_ROOT/central-infra"
APPS_DIR="$INFRA_ROOT/apps"
TEMPLATE_DIR="$INFRA_ROOT/template"
ROOT_ENV_TEMPLATE="$TEMPLATE_DIR/.env"
DASHBOARD_AUTH_TEMPLATE="$TEMPLATE_DIR/dashboard-auth.yml"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
  printf "%b[INFO]%b %s\n" "$YELLOW" "$NC" "$*"
}

log_success() {
  printf "%b[OK]%b %s\n" "$GREEN" "$NC" "$*"
}

log_error() {
  printf "%b[ERROR]%b %s\n" "$RED" "$NC" "$*" >&2
}

confirm() {
  local prompt="${1:-Are you sure?}"
  local answer=""
  read -r -p "$prompt [y/N]: " answer
  case "$answer" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

# Read a specific value from .env file
read_env_value() {
  local env_file="$1"
  local key="$2"

  while IFS='=' read -r k v; do
    [ -z "$k" ] && continue
    case "$k" in
      "#"*)
        continue
        ;;
      "$key")
        printf "%s" "$v"
        return 0
        ;;
    esac
  done < "$env_file"

  return 1
}

# Required environment variables for central infrastructure
REQUIRED_INFRA_VARS=(
  "BASE_DOMAIN"
  "MYSQL_ROOT_PASSWORD"
  "GF_SECURITY_ADMIN_PASSWORD"
  "TRAEFIK_DASHBOARD_AUTH"
)

# Validate required environment variables
validate_env_vars() {
  local env_file="$INFRA_ROOT/.env"
  local missing_vars=()
  local var_name var_value

  if [[ ! -f "$env_file" ]]; then
    log_error "Environment file not found: $env_file"
    log_error "Run './infra setup' first"
    exit 1
  fi

  for var_name in "${REQUIRED_INFRA_VARS[@]}"; do
    if ! var_value=$(read_env_value "$env_file" "$var_name") || [[ -z "$var_value" ]]; then
      missing_vars+=("$var_name")
    fi
  done

  if [[ ${#missing_vars[@]} -gt 0 ]]; then
    log_error "Missing required environment variables in .env:"
    for var_name in "${missing_vars[@]}"; do
      printf "  - %s\n" "$var_name" >&2
    done
    log_error ""
    log_error "Generate TRAEFIK_DASHBOARD_AUTH with:"
    log_error "  htpasswd -nbB admin <your-password> | sed 's/\$/\$\$/g'"
    exit 1
  fi

  log_success "All required environment variables are set"
}

# Generate Traefik dashboard auth middleware from env var
generate_dashboard_auth() {
  local env_file="$INFRA_ROOT/.env"
  local auth_file="$CENTRAL_INFRA_DIR/traefik/dynamic/dashboard-auth.yml"
  local auth_value

  if [ ! -f "$DASHBOARD_AUTH_TEMPLATE" ]; then
    log_error "Dashboard auth template not found: $DASHBOARD_AUTH_TEMPLATE"
    exit 1
  fi

  if ! auth_value=$(read_env_value "$env_file" "TRAEFIK_DASHBOARD_AUTH"); then
    log_error "TRAEFIK_DASHBOARD_AUTH not found in .env"
    exit 1
  fi

  # Escape special characters for sed replacement
  auth_value=$(printf '%s' "$auth_value" | sed 's/[&/]/\\&/g; s/\$/\\$/g')

  sed "s/\${TRAEFIK_DASHBOARD_AUTH}/$auth_value/g" "$DASHBOARD_AUTH_TEMPLATE" > "$auth_file"

  log_success "Generated dashboard auth middleware"
}

usage() {
  cat <<EOF
Usage: ./infra <command>

Central infrastructure management CLI for single-server setup.

Commands:
  setup    Idempotent environment setup
           - Checks prerequisites (Docker installed, daemon running)
           - Verifies ports 80/443 are available
           - Creates directory structure (apps/, central-infra/, etc.)
           - Generates .env template if not exists
           - Creates central-net Docker network (external)
           
  start    Start central infra, then all apps
           - Starts central-infra/compose.yml first
           - Discovers all valid apps in apps/ directory
           - Starts each app in alphabetical order
           - Traefik auto-detects and enables routing
           
  stop     Stop apps in reverse order, then central infra
           - Stops all apps in reverse alphabetical order
           - Stops central infrastructure last
           - Preserves all volume data (MySQL, Grafana, etc.)
           - Does not delete networks or files
           
  status   Show grouped running container status
           - Displays central infrastructure containers
           - Shows each app's containers separately
           - Includes container names, status, and ports
           
  archive  Create migration archive after confirmation
           - Prompts for confirmation
           - Stops all services (./infra stop)
           - Creates tarball of ~/infra and /var/lib/docker/volumes/
           - Output: infra-backup-YYYYMMDD-HHMMSS.tar.gz
           - Includes Origin Certificates, configs, and all data
           
  help     Show this help message

Examples:
  ./infra setup                # First-time setup
  ./infra start                # Start everything
  ./infra status               # Check status
  ./infra stop                 # Stop everything
  ./infra archive              # Create backup for migration

Notes:
  - All operations are idempotent where applicable
  - Volume data is never deleted by stop/archive commands
  - Must run 'setup' before first 'start'
  - Requires Docker and docker compose installed
EOF
}

require_file() {
  local file_path="$1"
  if [[ ! -f "$file_path" ]]; then
    log_error "Required file missing: $file_path"
    exit 1
  fi
}

check_prerequisites() {
  if ! command -v docker >/dev/null 2>&1; then
    log_error "Docker is not installed or not in PATH"
    exit 1
  fi

  if ! docker info >/dev/null 2>&1; then
    log_error "Docker daemon is not reachable"
    exit 1
  fi

  if command -v ss >/dev/null 2>&1; then
    if ss -ltn "( sport = :80 )" | grep -q ":80"; then
      log_error "Port 80 is already in use"
      exit 1
    fi
    if ss -ltn "( sport = :443 )" | grep -q ":443"; then
      log_error "Port 443 is already in use"
      exit 1
    fi
  else
    log_info "Skipping port check: 'ss' command is not available"
  fi
}

ensure_infra_structure() {
  mkdir -p "$APPS_DIR"
  mkdir -p "$CENTRAL_INFRA_DIR"
  mkdir -p "$CENTRAL_INFRA_DIR/traefik/dynamic"
  mkdir -p "$CENTRAL_INFRA_DIR/fragments"
  mkdir -p "$CENTRAL_INFRA_DIR/certs"
  mkdir -p "$CENTRAL_INFRA_DIR/maintenance"
  mkdir -p "$CENTRAL_INFRA_DIR/prometheus"
}

ensure_root_env() {
  local env_file="$INFRA_ROOT/.env"

  if [[ -f "$env_file" ]]; then
    log_info "Root .env already exists"
    return 0
  fi

  if [ ! -f "$ROOT_ENV_TEMPLATE" ]; then
    log_error "Root .env template not found: $ROOT_ENV_TEMPLATE"
    exit 1
  fi

  cp "$ROOT_ENV_TEMPLATE" "$env_file"
  log_success "Created .env template at $env_file"
  log_error "IMPORTANT: Edit $env_file and set all CHANGE_ME_* values before starting!"
}

ensure_central_network() {
  if docker network inspect central-net >/dev/null 2>&1; then
    log_info "Network central-net already exists"
  else
    docker network create central-net >/dev/null
    log_success "Created network central-net"
  fi
}

discover_apps() {
  local app_dir
  if [[ ! -d "$APPS_DIR" ]]; then
    return 0
  fi

  for app_dir in "$APPS_DIR"/*; do
    [[ -d "$app_dir" ]] || continue
    if [[ -f "$app_dir/.env" && -f "$app_dir/compose.base.yml" && -f "$app_dir/compose.attach.yml" ]]; then
      printf "%s\n" "$app_dir"
    fi
  done | sort
}

app_name_from_env() {
  local app_dir="$1"
  local app_name=""
  if [[ -f "$app_dir/.env" ]]; then
    # shellcheck disable=SC1090
    source "$app_dir/.env"
    app_name="${APP_NAME:-$(basename "$app_dir")}"
    printf "%s" "$app_name"
    return 0
  fi
  basename "$app_dir"
}

run_app_compose() {
  local app_dir="$1"
  shift

  local app_name
  app_name=$(app_name_from_env "$app_dir")

  docker compose \
    --env-file "$INFRA_ROOT/.env" \
    --env-file "$app_dir/.env" \
    -f "$app_dir/compose.base.yml" \
    -f "$app_dir/compose.attach.yml" \
    "$@"

  log_success "App '$app_name' command completed: $*"
}

start_central_infra() {
  require_file "$CENTRAL_INFRA_DIR/compose.yml"
  require_file "$INFRA_ROOT/.env"

  docker compose \
    --env-file "$INFRA_ROOT/.env" \
    -f "$CENTRAL_INFRA_DIR/compose.yml" \
    up -d
  log_success "Central infrastructure started"
}

stop_central_infra() {
  require_file "$CENTRAL_INFRA_DIR/compose.yml"
  require_file "$INFRA_ROOT/.env"

  docker compose \
    --env-file "$INFRA_ROOT/.env" \
    -f "$CENTRAL_INFRA_DIR/compose.yml" \
    down
  log_success "Central infrastructure stopped"
}

cmd_setup() {
  log_info "Running setup"
  check_prerequisites
  ensure_infra_structure
  ensure_root_env
  ensure_central_network

  log_success "Setup complete"
  printf "\nNext steps:\n"
  printf "  1) Edit %s/.env and configure all required variables\n" "$INFRA_ROOT"
  printf "     - BASE_DOMAIN: Your domain (e.g., example.com)\n"
  printf "     - MYSQL_ROOT_PASSWORD: Strong password for MySQL\n"
  printf "     - GF_SECURITY_ADMIN_PASSWORD: Strong password for Grafana\n"
  printf "     - TRAEFIK_DASHBOARD_AUTH: Generate with htpasswd -nbB admin <password>\n"
  printf "  2) Place Cloudflare Origin Certificate in central-infra/certs/\n"
  printf "  3) Start infra: ./infra start\n"
}

cmd_start() {
  log_info "Validating environment configuration"
  validate_env_vars
  generate_dashboard_auth

  log_info "Starting central infrastructure"
  start_central_infra

  local app_dirs=()
  local app_dir
  while IFS= read -r app_dir; do
    app_dirs+=("$app_dir")
  done < <(discover_apps)

  if [[ ${#app_dirs[@]} -eq 0 ]]; then
    log_info "No apps found in $APPS_DIR"
    return 0
  fi

  log_info "Starting apps in order"
  for app_dir in "${app_dirs[@]}"; do
    run_app_compose "$app_dir" up -d
  done

  log_success "All apps started"
}

cmd_stop() {
  local app_dirs=()
  local app_dir
  while IFS= read -r app_dir; do
    app_dirs+=("$app_dir")
  done < <(discover_apps)

  if [[ ${#app_dirs[@]} -gt 0 ]]; then
    log_info "Stopping apps in reverse order"
    local i
    for (( i=${#app_dirs[@]}-1; i>=0; i-- )); do
      run_app_compose "${app_dirs[i]}" down
    done
  else
    log_info "No apps found in $APPS_DIR"
  fi

  log_info "Stopping central infrastructure"
  stop_central_infra
}

print_status_group() {
  local title="$1"
  local project="$2"

  printf "\n%s\n" "$title"
  docker ps \
    --filter "label=com.docker.compose.project=$project" \
    --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
}

cmd_status() {
  print_status_group "Central Infra" "central-infra"

  local app_dirs=()
  local app_dir
  while IFS= read -r app_dir; do
    app_dirs+=("$app_dir")
  done < <(discover_apps)

  if [[ ${#app_dirs[@]} -eq 0 ]]; then
    printf "\nApps\n"
    printf "No app directories with compose files found.\n"
    return 0
  fi

  printf "\nApps\n"
  local project app_name
  for app_dir in "${app_dirs[@]}"; do
    app_name=$(app_name_from_env "$app_dir")
    project="$app_name"
    printf "\n[%s]\n" "$app_name"
    docker ps \
      --filter "label=com.docker.compose.project=$project" \
      --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"
  done
}

cmd_archive() {
  if ! confirm "This will stop all apps and central infra, then create an archive. Continue?"; then
    log_info "Archive cancelled"
    return 0
  fi

  "$INFRA_ROOT/infra" stop

  local timestamp archive_file
  timestamp=$(date +"%Y%m%d-%H%M%S")
  archive_file="$INFRA_ROOT/infra-backup-$timestamp.tar.gz"

  local source_root="$HOME/infra"
  if [[ ! -d "$source_root" ]]; then
    log_info "~/infra not found, using current INFRA_ROOT: $INFRA_ROOT"
    source_root="$INFRA_ROOT"
  fi

  tar -czf "$archive_file" "$source_root" /var/lib/docker/volumes/

  local size
  size=$(du -h "$archive_file" | cut -f1)
  log_success "Archive created: $archive_file"
  log_info "Archive size: $size"
}

main() {
  local command="${1:-help}"

  case "$command" in
    setup)
      cmd_setup
      ;;
    start)
      cmd_start
      ;;
    stop)
      cmd_stop
      ;;
    status)
      cmd_status
      ;;
    archive)
      cmd_archive
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      log_error "Unknown command: $command"
      usage
      exit 1
      ;;
  esac
}

main "$@"
